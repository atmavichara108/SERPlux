
{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "permission": {
    "edit": "allow",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "ls*": "allow",
      "cat*": "allow",
      "python -m pytest*": "allow",
      "python *": "allow",
      "git push*": "ask",
      "rm *": "ask"
    },
    "webfetch": "allow"
  },
  "agent": {
    "build": {
      "mode": "primary",
      "model": "opencode-go/qwen3.7-max",
      "temperature": 0.1,
      "steps": 30,
      "permission": { "task": { "*": "allow" } }
    },
    "plan": {
      "mode": "primary",
      "model": "opencode-go/qwen3.7-plus",
      "temperature": 0.1,
      "steps": 20,
      "permission": { "edit": "deny", "bash": "deny" }
    }
  }
}
