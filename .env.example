# Topvisor API
TOPVISOR_API_KEY=
TOPVISOR_USER_ID=
TOPVISOR_PROJECT_ID=

# LLM разметка (DeepSeek через opencode.ai/zen)
OPENCODE_API_KEY=

# Google Sheets
GOOGLE_SHEET_ID=
GOOGLE_CREDENTIALS_PATH=credentials.json

# Webhook (FastAPI)
WEBHOOK_SECRET=
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000

# База данных (по умолчанию ./serplux.db, в контейнере /app/data/serplux.db)
DB_PATH=serplux.db

# Карта регионов (по умолчанию regions_map.json)
# Для второго клиента: REGIONS_MAP=regions_map_client2.json
REGIONS_MAP=regions_map.json
